#define FinishImprovisedPickaxeTier

    StructureRemoveGear(global.Structure_ImprovisedWorkstation, global.Gear_Pickaxe);
    StructureRemoveItem(global.Structure_ImprovisedWorkstation, global.Item_Fist);
    
#define FinishStonePickaxeTier

    StructureRemoveGear(global.Structure_Workstation, global.Gear_Pickaxe);
    StructureRemoveItem(global.Structure_Workstation, global.Item_Fist);
#define FinishSkullPickaxeTier

    StructureRemoveGear(global.Structure_Anvil, global.Gear_Pickaxe);
    StructureRemoveItem(global.Structure_Anvil, global.Item_Fist);
#define FinishImprovisedSwordTier

